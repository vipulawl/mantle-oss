generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Install {
  id              String    @id
  shopDomain      String
  shopName        String?
  plan            String?
  status          String    @default("active") // active | churned
  installedAt     DateTime
  uninstalledAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Transaction {
  id          String   @id
  shopDomain  String
  type        String   // SALE | REFUND | PENDING_CHARGE
  amount      Float
  currency    String   @default("USD")
  plan        String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())
}

model Review {
  id          String   @id
  author      String
  rating      Int
  body        String?
  reviewedAt  DateTime
  syncedAt    DateTime @default(now())
}

model SyncMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
